# Example correlated env vars for a disposable agent local stack.
# Prefer ./scripts/start-agent-stack.sh, which writes .env.agent-stack for you.

AGENT_STACK_SUFFIX=54043
API_PORT=38888
FRONTEND_PORT=44200
API_URL=http://127.0.0.1:38888
FRONTEND_URL=http://127.0.0.1:44200

EZRULES_DB_ENDPOINT=postgresql://postgres:root@localhost:5432/ezrules_e2e_54043
EZRULES_APP_SECRET=dev_secret
EZRULES_ORG_ID=1
EZRULES_TESTING=true
EZRULES_APP_BASE_URL=http://127.0.0.1:44200
EZRULES_CORS_ALLOWED_ORIGINS=http://127.0.0.1:44200
EZRULES_FRONTEND_API_URL=http://127.0.0.1:38888

E2E_BASE_URL=http://127.0.0.1:44200
E2E_API_BASE_URL=http://127.0.0.1:38888
E2E_MAILPIT_BASE_URL=http://localhost:8025

AGENT_STACK_ADMIN_EMAIL=admin@example.com
AGENT_STACK_ADMIN_PASSWORD=admin
AGENT_STACK_ORG_NAME=agent-stack
