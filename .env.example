# Copy this file to .env for docker-compose.prod.yml.
# The production compose stack sets the internal database endpoint itself.

EZRULES_APP_SECRET=replace-with-a-random-secret
EZRULES_ORG_NAME=your-org
EZRULES_ADMIN_EMAIL=admin@example.com
EZRULES_ADMIN_PASSWORD=change-me

# Optional overrides.
# Leave these unset to use the bundled local Mailpit container.
# EZRULES_SMTP_HOST=mail.example.com
# EZRULES_SMTP_PORT=587
# EZRULES_SMTP_USER=mailer-user
# EZRULES_SMTP_PASSWORD=mailer-password
# EZRULES_FROM_EMAIL=no-reply@example.com
# EZRULES_APP_BASE_URL=http://localhost:4200
