{
  "name": "ezrules-frontend",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "node ./scripts/start-with-runtime-config.mjs",
    "build": "npm run write-runtime-config && ng build",
    "watch": "ng build --watch --configuration development",
    "write-runtime-config": "node ./scripts/write-runtime-config.mjs",
    "tdest": "ng test",
    "test:e2e": "playwright test --timeout=30000",
    "test:e2e:verbose": "playwright test --timeout=30000 --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:heaed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.0.0",
    "@angular/common": "^18.0.0",
    "@angular/compiler": "^18.0.0",
    "@angular/core": "^18.0.0",
    "@angular/forms": "^18.0.0",
    "@angular/platform-browser": "^18.0.0",
    "@angular/platform-browser-dynamic": "^18.0.0",
    "@angular/router": "^18.0.0",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "@types/diff": "^7.0.2",
    "chart.js": "^4.5.1",
    "codemirror": "^6.0.2",
    "diff": "^8.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.0.0",
    "@angular/cli": "^18.0.0",
    "@angular/compiler-cli": "^18.0.0",
    "@playwright/test": "^1.58.1",
    "@types/jasmine": "~5.1.0",
    "autoprefixer": "^10.4.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.4.2"
  }
}
